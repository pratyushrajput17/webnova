generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String    @id @default(cuid())
  clerkId             String    @unique
  email               String    @unique
  name                String?
  role                String    @default("FREE")
  plan                String    @default("FREE")
  monthlyAuditCount   Int       @default(0)
  lastResetDate       DateTime?
  competitorCount     Int       @default(0)
  competitorLastReset DateTime?
  subscriptionEndsAt  DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  audits              Audit[]
  redeemedBy          RedeemCode[]
  usageHistory        UsageHistory[]
  subscriptions       UserSubscription[]
  redeemHistory       RedeemHistory[]
  notifications       Notification[]
  competitorComparisons CompetitorComparison[]
}

model UsageHistory {
  id         String   @id @default(cuid())
  userId     String
  actionType String
  websiteUrl String?
  resultData Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, createdAt])
  @@index([userId, actionType, createdAt])
}

model UserSubscription {
  id         String    @id @default(cuid())
  userId     String
  plan       String
  status     String    @default("active")
  startsAt   DateTime  @default(now())
  endsAt     DateTime?
  isLifetime Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, status])
}

model RedeemHistory {
  id        String    @id @default(cuid())
  userId    String
  code      String
  plan      String
  usedAt    DateTime  @default(now())
  expiresAt DateTime?

  user   User       @relation(fields: [userId], references: [id])
  redeem RedeemCode @relation(fields: [codeId], references: [id])
  codeId String

  @@index([userId])
}

model CompetitorComparison {
  id              String   @id @default(cuid())
  userId          String
  yourSite        String
  competitorSite  String
  yourData        Json
  competitorData  Json
  comparison      Json
  summary         String
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model RedeemCode {
  id           String    @id @default(cuid())
  code         String    @unique
  plan         String
  duration     Int       @default(365)
  isUsed       Boolean   @default(false)
  usedByUserId String?
  usedBy       User?     @relation(fields: [usedByUserId], references: [id])
  usedAt       DateTime?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  redeemHistory RedeemHistory[]

  @@index([plan])
  @@index([isUsed])
}

model Audit {
  id                  String   @id @default(cuid())
  userId              String
  websiteUrl          String
  pageTitle           String
  metaDescription     String?
  seoScore            Int
  performanceScore    Int      @default(0)
  accessibilityScore  Int      @default(0)
  h1Count             Int
  h1Tags              Json     @default("[]")
  h2Tags              Json     @default("[]")
  h3Tags              Json     @default("[]")
  canonicalUrl        String?
  imageCount          Int
  missingAltCount     Int
  imagesData          Json     @default("[]")
  missingAltImages    Json     @default("[]")
  internalLinks       Int
  internalLinksData   Json     @default("[]")
  externalLinks       Int
  externalLinksData   Json     @default("[]")
  titleLength         Int      @default(0)
  metaDescriptionLength Int    @default(0)
  aiRecommendations   Json     @default("[]")
  auditType           String   @default("standard")
  createdAt           DateTime @default(now())
  user                User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, createdAt])
  @@index([userId, auditType])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}
